   "source": [
    "# NefroQuest — Revisão de Questões (gpt-5.4)\n",
    "\n",
    "**Ordem de execução:**\n",
    "1. **Célula 1** — Cole a API key e rode\n",
    "2. **Célula 2** — Monte o Google Drive (salva progresso automaticamente)\n",
    "3. **Célula 3** — Faça upload dos 3 arquivos\n",
    "4. **Célula 4** — Rode a revisão completa\n",
    "5. **Célula 5** *(opcional)* — Retentar questões com erro de API\n",
    "\n",
    "> **Arquivos necessários** (baixar do branch `claude/nefroquest-question-counter-YslTs`):\n",
    "> - `index_original.html` → renomear para `index.html` antes do upload\n",
    "> - `review_questions.py`\n",
    "> - `apply_reviews.py`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-1",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════\n",
    "# CÉLULA 1 — API Key\n",
    "# ══════════════════════════════════════════════════════════\n",
    "OPENAI_API_KEY = \"sk-...\"  # ← substitua pela sua chave\n",
    "\n",
    "import os\n",
    "os.environ[\"OPENAI_API_KEY\"] = OPENAI_API_KEY\n",
    "!pip install -q openai\n",
    "print(\"✓ Pronto. Rode a Célula 2.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════\n",
    "# CÉLULA 2 — Google Drive (salva progresso automaticamente)\n",
    "# Se cair a conexão, os lotes já feitos ficam salvos aqui.\n",
    "# ══════════════════════════════════════════════════════════\n",
    "from google.colab import drive\n",
    "import os, shutil, glob\n",
    "\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "DRIVE_FOLDER = '/content/drive/MyDrive/nefroquest_reviews'\n",
    "os.makedirs(DRIVE_FOLDER, exist_ok=True)\n",
    "\n",
    "# Restaura lotes já feitos do Drive\n",
    "restored = 0\n",
    "for f in sorted(glob.glob(f'{DRIVE_FOLDER}/reviewed_*.json')):\n",
    "    name = os.path.basename(f)\n",
    "    shutil.copy(f, f'/content/{name}')\n",
    "    print(f'  Restaurado: {name}')\n",
    "    restored += 1\n",
    "\n",
    "if restored == 0:\n",
    "    print('Nenhum lote anterior encontrado — começando do zero.')\n",
    "else:\n",
    "    print(f'\\n✓ {restored} lote(s) restaurado(s). A Célula 4 vai pulá-los automaticamente.')\n",
    "\n",
    "print('\\nRode a Célula 3.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════\n",
    "# CÉLULA 3 — Upload dos arquivos\n",
    "# Necessários: index.html · review_questions.py · apply_reviews.py\n",
    "# ATENÇÃO: renomeie index_original.html para index.html antes do upload\n",
    "# ══════════════════════════════════════════════════════════\n",
    "from google.colab import files\n",
    "import re\n",
    "\n",
    "print('Selecione os 3 arquivos: index.html, review_questions.py, apply_reviews.py')\n",
    "uploaded = files.upload()\n",
    "\n",
    "needed  = {'index.html', 'review_questions.py', 'apply_reviews.py'}\n",
    "missing = needed - set(uploaded.keys())\n",
    "if missing:\n",
    "    print(f'\\n⚠ Faltando: {missing} — rode esta célula novamente.')\n",
    "else:\n",
    "    with open('index.html', encoding='utf-8') as f:\n",
    "        html = f.read()\n",
    "    bloco = html[html.find('const topics = ['):html.find('\\n];', html.find('const topics = ['))]\n",
    "    n = len(re.findall(r'\"t\":', bloco))\n",
    "    print(f'\\n✓ Uploads OK. Questões encontradas: {n}')\n",
    "    print('Rode a Célula 4.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════\n",
    "# CÉLULA 4 — Revisão completa\n",
    "# Modelo: gpt-5.4 com effort=high\n",
    "# Tempo estimado: 2–3h para 1034 questões\n",
    "# Se desconectar: rode Células 1→2→3→4 novamente.\n",
    "# Os lotes prontos serão restaurados do Drive automaticamente.\n",
    "# ══════════════════════════════════════════════════════════\n",
    "import subprocess, json, os, shutil\n",
    "from google.colab import files\n",
    "\n",
    "TOTAL      = 1034\n",
    "BATCH_SZ   = 100\n",
    "DRIVE_FOLDER = '/content/drive/MyDrive/nefroquest_reviews'\n",
    "\n",
    "batches = []\n",
    "s = 0\n",
    "while s < TOTAL:\n",
    "    batches.append((s, min(s + BATCH_SZ, TOTAL)))\n",
    "    s += BATCH_SZ\n",
    "\n",
    "total_ok  = 0\n",
    "total_err = 0\n",
    "\n",
    "for i, (s, e) in enumerate(batches):\n",
    "    out = f'reviewed_{s}_{e}.json'\n",
    "\n",
    "    # ── Checkpoint: pula lote já feito ──────────────────\n",
    "    if os.path.exists(out):\n",
    "        with open(out) as f_:\n",
    "            data = json.load(f_)\n",
    "        ok = sum(1 for r in data if not r.get('_error'))\n",
    "        print(f'[Lote {i+1:02d}/{len(batches)}] {s}–{e}: JÁ FEITO ({ok}/{e-s} OK) — pulando')\n",
    "        total_ok  += ok\n",
    "        total_err += (e - s) - ok\n",
    "        continue\n",
    "\n",
    "    # ── Revisão via gpt-5.4 ──────────────────────────────\n",
    "    print(f'\\n[Lote {i+1:02d}/{len(batches)}] Revisando questões {s}–{e-1}...')\n",
    "    r = subprocess.run(\n",
    "        ['python', 'review_questions.py',\n",
    "         '--start', str(s), '--end', str(e), '--out', out]\n",
    "    )\n",
    "\n",
    "    if r.returncode != 0 or not os.path.exists(out):\n",
    "        print(f'  ERRO no lote {i+1}. Verifique a API key e rode novamente.')\n",
    "        break\n",
    "\n",
    "    with open(out) as f_:\n",
    "        data = json.load(f_)\n",
    "    ok  = sum(1 for r_ in data if not r_.get('_error'))\n",
    "    err = len(data) - ok\n",
    "    total_ok  += ok\n",
    "    total_err += err\n",
    "\n",
    "    # ── Aplica ao index.html ─────────────────────────────\n",
    "    subprocess.run(['python', 'apply_reviews.py', out])\n",
    "\n",
    "    # ── Salva no Drive ───────────────────────────────────\n",
    "    shutil.copy(out, f'{DRIVE_FOLDER}/{out}')\n",
    "    shutil.copy('index.html', f'{DRIVE_FOLDER}/index.html')\n",
    "\n",
    "    print(f'  → {ok} revisadas OK | {err} com erro  ✓ Drive salvo')\n",
    "\n",
    "print(f\"\"\"\n",
    "════════════════════════════════\n",
    "CONCLUÍDO\n",
    "  Revisadas com sucesso : {total_ok}\n",
    "  Com erro de API       : {total_err}\n",
    "  index.html final      : {os.path.getsize('index.html'):,} bytes\n",
    "════════════════════════════════\n",
    "Baixando index.html...\n",
    "\"\"\")\n",
    "files.download('index.html')"
   ]
  },
  {
